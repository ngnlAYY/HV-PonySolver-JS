{
  "name": "hv-pony-solver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "ws": "8.20.1"
    }
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "test": "corepack pnpm -r test && node --test scripts/check-docs-drift.test.mjs && node --test scripts/check-architecture-boundaries.test.mjs",
    "test:coverage": "corepack pnpm -r test:coverage",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "eslint .",
    "docs:check": "node scripts/check-docs-drift.mjs",
    "architecture:check": "node scripts/check-architecture-boundaries.mjs",
    "format": "prettier --write .",
    "check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm test:coverage && corepack pnpm docs:check && corepack pnpm architecture:check && corepack pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-istanbul": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.1.0"
  }
}
