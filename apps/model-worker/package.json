{
  "name": "@hv-pony-solver/model-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "render-config": "node scripts/render-wrangler-config.mjs",
    "dev": "pnpm render-config && wrangler dev",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && node --test scripts/render-wrangler-config.test.mjs",
    "test:coverage": "vitest run --coverage",
    "deploy": "HV_PONY_SOLVER_RENDER_ENV=deploy pnpm render-config && node scripts/validate-wrangler-config.mjs && wrangler deploy"
  },
  "dependencies": {
    "@hv-pony-solver/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.6",
    "@cloudflare/workers-types": "^4.20260516.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.50.0"
  }
}
